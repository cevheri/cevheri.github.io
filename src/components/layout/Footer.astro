    href: "https://www.linkedin.com/in/cevheribozoglan/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM6.918 20.452H3.756V9h3.162v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.205 24 24 23.227 24 22.271V1.729C24 .774 23.205 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "Medium",
    href: "https://cevheri.medium.com/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42zm3.04 0c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75c.66 0 1.19 2.58 1.19 5.75z"/></svg>`,
  },
  {
    label: "ResearchGate",
    href: "https://www.researchgate.net/profile/Mehmet-Cevheri-Bozoglan",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M19.586 0c-1.37 0-2.573.81-3.109 1.98h-.002C14.54.55 12.18 0 10.2 0 4.563 0 0 4.563 0 10.2c0 5.636 4.563 10.2 10.2 10.2 3.1 0 5.876-1.387 7.748-3.572C19.53 18.72 21.395 20.4 24 20.4v-2.4c-1.77 0-3.2-1.43-3.2-3.2V10.2c0-.59-.05-1.17-.138-1.74.678-.97 1.538-1.66 2.538-1.66.77 0 1.4.63 1.4 1.4h2.4c0-2.1-1.7-3.8-3.8-3.8-.91 0-1.73.32-2.414.86zm-9.386 2.4c4.52 0 7.8 3.48 7.8 7.8 0 4.32-3.28 7.8-7.8 7.8-4.52 0-7.8-3.48-7.8-7.8 0-4.32 3.28-7.8 7.8-7.8zm.8 3.6v3.2H7.8v2.4h3.2v3.2h2.4v-3.2H16.6V9.2h-3.2V6z"/></svg>`,
  },
  {
    label: "ORCID",
    href: "https://orcid.org/0009-0006-4963-1403",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378a.87.87 0 1 1 0 1.74.87.87 0 0 1 0-1.74zm-.578 3.199h1.156v10.845H6.791V7.577zm3.685 0h3.127c3.049 0 4.926 2.129 4.926 5.402 0 3.273-1.877 5.443-4.926 5.443h-3.127V7.577zm1.156 1.079v8.687h1.971c2.39 0 3.674-1.705 3.674-4.364 0-2.66-1.283-4.323-3.674-4.323h-1.971z"/></svg>`,
  },
];
---

<footer
  class="border-t border-[var(--color-neutral-200)] dark:border-[var(--color-neutral-800)]"
>
  <div
    class="mx-auto flex max-w-[var(--container-max)] flex-col items-center gap-[var(--spacing-6)] px-[var(--spacing-6)] py-[var(--spacing-12)]"
  >
    <!-- Social links -->
    <nav class="flex items-center gap-[var(--spacing-4)]" aria-label="Social links">
      {
        socialLinks.map(({ label, href, icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-neutral-500)] transition-colors duration-150 hover:text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-500)] dark:hover:text-[var(--color-neutral-100)]"
            aria-label={label}
          >
            <Fragment set:html={icon} />
          </a>
        ))
      }
    </nav>

    <!-- Copyright -->
    <p class="text-sm text-[var(--color-neutral-500)]">
      &copy; {currentYear} Cevheri Bozoglan. All rights reserved.
    </p>
  </div>
</footer>
