---
/**
 * Shared <head> component rendered on every page.
 * Handles meta tags, OG/Twitter cards, JSON-LD, theme init, and global CSS.
 */
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
  ogType?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
}

const SITE_NAME = "Cevheri Bozoglan";
const SITE_URL = "https://cevheri.github.io";

const { title, description, ogImage, canonicalUrl, jsonLd, ogType, articlePublishedTime, articleModifiedTime, articleTags } = Astro.props;

const pageTitle = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;
const resolvedOgImage = ogImage
  ? new URL(ogImage, SITE_URL).href
  : new URL("/og-default.png", SITE_URL).href;
const resolvedCanonical = canonicalUrl ?? Astro.url.href;

const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": SITE_URL + "/#person",
  name: "Mehmet Cevheri Bozoglan",
  alternateName: "Cevheri Bozoglan",
  url: SITE_URL,
  jobTitle: "Senior Full-Stack Engineer",
  description: "Senior full-stack engineer with 10+ years of experience, specializing in Java, Spring Boot, Flutter, AI Engineering, and cloud-native architectures.",
  worksFor: {
    "@type": "Organization",
    name: "PiA Group",
    url: "https://www.pia-group.net/",
  },
  alumniOf: {
    "@type": "Organization",
    name: "Intellica",
    url: "https://intellica-tech.github.io/",
  },
  knowsAbout: [
    "Java", "Spring Boot", "Flutter", "React", "Next.js", "Python",
    "FastAPI", "TypeScript", "AI Engineering", "LLM", "GenAI",
    "Microservices", "Docker", "Kubernetes", "Cloud Architecture",
  ],
  sameAs: [
    "https://github.com/cevheri",
    "https://www.linkedin.com/in/cevheribozoglan/",
    "https://cevheri.medium.com/",
    "https://www.researchgate.net/profile/Mehmet-Cevheri-Bozoglan",
    "https://orcid.org/0009-0006-4963-1403",
  ],
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- SEO -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />

<!-- Open Graph -->
<meta property="og:type" content={ogType ?? "website"} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

<!-- Additional OG tags -->
<meta property="og:site_name" content="Cevheri Bozoglan" />
<meta property="og:locale" content="en_US" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={description} />

<!-- Article-specific OG tags (only if articlePublishedTime is set) -->
{ogType === "article" && articlePublishedTime && (
  <>
    <meta property="article:published_time" content={articlePublishedTime} />
    {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    <meta property="article:author" content="Mehmet Cevheri Bozoglan" />
    {articleTags && articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- Additional SEO meta -->
<meta name="author" content="Mehmet Cevheri Bozoglan" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

<!-- Theme initialisation — inline to prevent FOUC -->
<script is:inline>
  (function () {
    function getThemePreference() {
      var stored = localStorage.getItem("theme");
      if (stored === "light" || stored === "dark") return stored;
      return null; // no preference saved yet
    }

    function applyTheme() {
      var pref = getThemePreference();
      // Default to dark if user hasn't explicitly chosen
      var resolved = pref === "light" ? "light" : "dark";
      document.documentElement.classList.toggle("dark", resolved === "dark");
    }

    // Apply immediately (before first paint)
    applyTheme();

    // Re-apply after Astro ViewTransitions swap
    document.addEventListener("astro:after-swap", applyTheme);
  })();
</script>
