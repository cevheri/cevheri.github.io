---
/**
 * Responsive site header with navigation, theme toggle, and mobile menu trigger.
 * Fixed at top with backdrop-blur.
 */
import ThemeToggle from "@components/ui/ThemeToggle.astro";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/contributions", label: "Contributions" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-[var(--color-neutral-200)] bg-[var(--color-neutral-50)]/80 backdrop-blur-lg dark:border-[var(--color-neutral-800)] dark:bg-[var(--color-neutral-950)]/80"
>
  <div
    class="mx-auto flex h-16 max-w-[var(--container-max)] items-center justify-between px-[var(--spacing-6)]"
  >
    <!-- Logo / Site name -->
    <a
      href="/"
      class="text-base font-semibold tracking-tight text-[var(--color-neutral-900)] transition-colors hover:text-[var(--color-accent-500)] dark:text-[var(--color-neutral-100)] dark:hover:text-[var(--color-accent-400)]"
    >
      Cevheri Bozoglan
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden items-center gap-[var(--spacing-1)] md:flex" aria-label="Main navigation">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "rounded-[var(--radius-md)] px-[var(--spacing-3)] py-[var(--spacing-2)] text-sm font-medium transition-colors duration-150",
                isActive
                  ? "bg-[var(--color-neutral-200)] text-[var(--color-neutral-900)] dark:bg-[var(--color-neutral-800)] dark:text-[var(--color-neutral-100)]"
                  : "text-[var(--color-neutral-600)] hover:bg-[var(--color-neutral-100)] hover:text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-400)] dark:hover:bg-[var(--color-neutral-850)] dark:hover:text-[var(--color-neutral-100)]",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Right section: theme toggle + mobile hamburger -->
    <div class="flex items-center gap-[var(--spacing-1)]">
      <ThemeToggle />

      <!-- Mobile menu trigger -->
      <button
        type="button"
        id="mobile-nav-open"
        class="inline-flex h-9 w-9 items-center justify-center rounded-[var(--radius-md)] text-[var(--color-neutral-600)] transition-colors hover:bg-[var(--color-neutral-200)] hover:text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-400)] dark:hover:bg-[var(--color-neutral-800)] dark:hover:text-[var(--color-neutral-100)] md:hidden"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg
          class="h-5 w-5"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Spacer so content isn't hidden behind the fixed header -->
<div class="h-16" aria-hidden="true"></div>
