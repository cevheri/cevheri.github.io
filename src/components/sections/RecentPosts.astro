---
/**
 * Recent blog posts section.
 * Shows the latest 3 non-draft posts sorted by publication date.
 */
import { getCollection } from "astro:content";
import { formatDate } from "@lib/utils";
import { calculateReadingTime } from "@lib/reading-time";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";
import Button from "@components/ui/Button.astro";

const allPosts = await getCollection("blog");

const recentPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<section
  class="mx-auto max-w-[var(--container-max)] px-[var(--spacing-6)] py-[var(--spacing-16)]"
>
  {
    recentPosts.length > 0 && (
      <>
        {/* Section header */}
        <div class="mb-[var(--spacing-10)] flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)] sm:text-3xl">
              Recent Posts
            </h2>
            <p class="mt-[var(--spacing-2)] text-[var(--color-neutral-600)] dark:text-[var(--color-neutral-400)]">
              Articles, tutorials, and research papers
            </p>
          </div>
          <a
            href="/blog"
            class="hidden text-sm font-medium text-[var(--color-accent-500)] hover:text-[var(--color-accent-600)] dark:hover:text-[var(--color-accent-400)] sm:inline-flex sm:items-center sm:gap-1"
          >
            View All Posts
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        {/* Posts list */}
        <div class="grid gap-[var(--spacing-6)]">
          {recentPosts.map((post) => {
            const href = post.data.externalUrl
              ? post.data.externalUrl
              : `/blog/${post.id}`;
            const isExternal = !!post.data.externalUrl;
            const readingTime = calculateReadingTime(post.body ?? "");

            return (
              <Card href={href} class={isExternal ? undefined : undefined}>
                <div class="flex flex-col gap-[var(--spacing-3)] sm:flex-row sm:items-start sm:justify-between sm:gap-[var(--spacing-6)]">
                  <div class="flex-1">
                    <h3 class="text-lg font-semibold text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)]">
                      {post.data.title}
                      {isExternal && (
                        <svg
                          class="ml-1 inline-block h-4 w-4 text-[var(--color-neutral-400)]"
                          viewBox="0 0 16 16"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          aria-label="External link"
                        >
                          <path d="M6.5 3.5h-3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-3M9.5 2.5h4v4M13.5 2.5l-6 6" />
                        </svg>
                      )}
                    </h3>
                    <p class="mt-[var(--spacing-1)] text-sm leading-relaxed text-[var(--color-neutral-600)] dark:text-[var(--color-neutral-400)]">
                      {post.data.description}
                    </p>

                    {/* Tags */}
                    <div class="mt-[var(--spacing-3)] flex flex-wrap gap-[var(--spacing-1)]">
                      {post.data.tags.slice(0, 4).map((tag) => (
                        <Badge text={tag} />
                      ))}
                    </div>
                  </div>

                  {/* Meta (date + reading time) */}
                  <div class="flex shrink-0 items-center gap-[var(--spacing-3)] text-xs text-[var(--color-neutral-500)] dark:text-[var(--color-neutral-400)] sm:flex-col sm:items-end sm:gap-[var(--spacing-1)]">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span>{readingTime}</span>
                  </div>
                </div>
              </Card>
            );
          })}
        </div>

        {/* Mobile "View All" link */}
        <div class="mt-[var(--spacing-8)] text-center sm:hidden">
          <Button href="/blog" variant="secondary" size="md">
            View All Posts
          </Button>
        </div>
      </>
    )
  }
</section>
