---
/**
 * Standard page layout — used for static pages like About, Projects, etc.
 * Extends BaseLayout with a page header and content container.
 */
import BaseLayout from "@layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} jsonLd={jsonLd}>
  <article class="mx-auto max-w-[var(--container-max)] px-[var(--spacing-6)] py-[var(--spacing-12)]">
    <!-- Page header -->
    <header class="mb-[var(--spacing-10)]">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)] sm:text-4xl"
      >
        {title}
      </h1>
    </header>

    <!-- Page content -->
    <div class="mx-auto max-w-[var(--content-max)]">
      <slot />
    </div>
  </article>
</BaseLayout>
