---
/**
 * Root layout wrapping every page on the site.
 * Provides document shell, head, header, footer, and ViewTransitions.
 */
import { ClientRouter } from "astro:transitions";
import BaseHead from "@components/layout/BaseHead.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import MobileNav from "@components/layout/MobileNav.astro";
import SkipToContent from "@components/ui/SkipToContent.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
  ogType?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
}

const { title, description, ogImage, canonicalUrl, jsonLd, ogType, articlePublishedTime, articleModifiedTime, articleTags } = Astro.props;
---

<!doctype html>
<html lang="en" class="">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
      jsonLd={jsonLd}
      ogType={ogType}
      articlePublishedTime={articlePublishedTime}
      articleModifiedTime={articleModifiedTime}
      articleTags={articleTags}
    />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    <SkipToContent />
    <Header />
    <MobileNav />
    <main id="content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
