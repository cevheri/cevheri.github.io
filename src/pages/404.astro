---
/**
 * Custom 404 page — minimal, centered design with a link back to home.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found" description="The page you are looking for does not exist or has been moved.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center px-[var(--spacing-6)] py-[var(--spacing-20)] text-center">
    <p class="text-8xl font-bold tracking-tighter text-[var(--color-neutral-200)] dark:text-[var(--color-neutral-800)] sm:text-9xl">
      404
    </p>

    <h1 class="mt-[var(--spacing-6)] text-2xl font-semibold tracking-tight text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)] sm:text-3xl">
      Page Not Found
    </h1>

    <p class="mt-[var(--spacing-4)] max-w-md text-[var(--color-neutral-600)] dark:text-[var(--color-neutral-400)]">
      The page you are looking for does not exist or has been moved.
    </p>

    <a
      href="/"
      class="mt-[var(--spacing-8)] inline-flex items-center gap-[var(--spacing-2)] rounded-[var(--radius-md)] bg-[var(--color-accent-500)] px-[var(--spacing-6)] py-[var(--spacing-3)] text-sm font-medium text-white transition-colors duration-200 hover:bg-[var(--color-accent-600)]"
    >
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5" /><polyline points="12 19 5 12 12 5" />
      </svg>
      Back to Home
    </a>
  </section>
</BaseLayout>
