---
/**
 * Projects page — grid of open-source projects enriched with GitHub stats.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { enrichProjects } from "@lib/github";
import type { ProjectData } from "@lib/github";

const rawProjects = await getCollection("projects");

// Map content collection entries to ProjectData shape
const projectDataArray: ProjectData[] = rawProjects.map((entry) => ({
  ...entry.data,
}));

// Enrich with GitHub stats (gracefully degrades on failure)
const enriched = await enrichProjects(projectDataArray);

// Sort: featured first, then by sortOrder
const sorted = enriched.sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return a.sortOrder - b.sortOrder;
});
const projects = sorted;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projects — Cevheri Bozoglan",
  description: "Open-source projects and applications built by Cevheri Bozoglan.",
  url: "https://cevheri.github.io/projects",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: sorted.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "SoftwareSourceCode",
        name: project.name,
        description: project.tagline,
        codeRepository: `https://github.com/${project.repo}`,
        programmingLanguage: project.techStack,
        author: { "@id": "https://cevheri.github.io/#person" },
      },
    })),
  },
};
---

<BaseLayout title="Projects" description="Open-source projects and applications I've built." jsonLd={jsonLd}>
  <section class="mx-auto max-w-[var(--container-max)] px-[var(--spacing-6)] py-[var(--spacing-12)]">
    <!-- Page header -->
    <header class="mb-[var(--spacing-10)]">
      <h1 class="text-3xl font-bold tracking-tight text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)] sm:text-4xl">
        Projects
      </h1>
      <p class="mt-[var(--spacing-3)] max-w-[var(--content-max)] text-lg text-[var(--color-neutral-600)] dark:text-[var(--color-neutral-400)]">
        Open-source projects and applications I've built. Each project reflects my passion for clean architecture, developer experience, and solving real-world problems.
      </p>
    </header>

    <!-- Project grid -->
    <div class="grid gap-[var(--spacing-6)] sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <article
          class="group relative flex flex-col rounded-[var(--radius-lg)] border border-[var(--color-neutral-200)] bg-[var(--color-neutral-50)] p-[var(--spacing-6)] transition-all duration-200 hover:border-[var(--color-neutral-300)] hover:shadow-[var(--shadow-md)] dark:border-[var(--color-neutral-800)] dark:bg-[var(--color-neutral-950)] dark:hover:border-[var(--color-neutral-700)]"
        >
          {/* Featured indicator */}
          {project.featured && (
            <span class="absolute top-[var(--spacing-4)] right-[var(--spacing-4)] rounded-[var(--radius-full)] bg-[var(--color-accent-500)]/10 px-[var(--spacing-3)] py-[var(--spacing-1)] text-xs font-semibold text-[var(--color-accent-500)] dark:bg-[var(--color-accent-400)]/10 dark:text-[var(--color-accent-400)]">
              Featured
            </span>
          )}

          {/* Header */}
          <div class="mb-[var(--spacing-3)]">
            <h2 class="text-lg font-semibold text-[var(--color-neutral-900)] dark:text-[var(--color-neutral-100)]">
              {project.name}
            </h2>
            <p class="mt-[var(--spacing-1)] text-sm leading-relaxed text-[var(--color-neutral-600)] dark:text-[var(--color-neutral-400)]">
              {project.tagline}
            </p>
          </div>

          {/* Tech stack badges */}
          <div class="mb-[var(--spacing-4)] flex flex-wrap gap-[var(--spacing-1)]">
            {project.techStack.map((tech) => (
              <span class="rounded-[var(--radius-sm)] bg-[var(--color-neutral-100)] px-[var(--spacing-2)] py-0.5 text-xs font-medium text-[var(--color-neutral-600)] dark:bg-[var(--color-neutral-800)] dark:text-[var(--color-neutral-400)]">
                {tech}
              </span>
            ))}
            <span class="rounded-[var(--radius-sm)] bg-[var(--color-accent-500)]/10 px-[var(--spacing-2)] py-0.5 text-xs font-medium text-[var(--color-accent-500)] dark:bg-[var(--color-accent-400)]/10 dark:text-[var(--color-accent-400)]">
              {project.category}
            </span>
          </div>

          {/* Stats */}
          {(project.stars != null || project.forks != null) && (
            <div class="mb-[var(--spacing-4)] flex items-center gap-[var(--spacing-4)] text-sm text-[var(--color-neutral-500)] dark:text-[var(--color-neutral-400)]">
              {project.stars != null && project.stars > 0 && (
                <span class="inline-flex items-center gap-[var(--spacing-1)]">
                  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                  </svg>
                  {project.stars}
                </span>
              )}
              {project.forks != null && project.forks > 0 && (
                <span class="inline-flex items-center gap-[var(--spacing-1)]">
                  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="18" r="3" /><circle cx="6" cy="6" r="3" /><circle cx="18" cy="6" r="3" />
                    <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9" /><path d="M12 12v3" />
                  </svg>
                  {project.forks}
                </span>
              )}
            </div>
          )}

          {/* Spacer to push links to bottom */}
          <div class="mt-auto flex items-center gap-[var(--spacing-3)] pt-[var(--spacing-4)] border-t border-[var(--color-neutral-200)] dark:border-[var(--color-neutral-800)]">
            <a
              href={`https://github.com/${project.repo}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-[var(--spacing-2)] text-sm font-medium text-[var(--color-neutral-700)] transition-colors hover:text-[var(--color-accent-500)] dark:text-[var(--color-neutral-300)] dark:hover:text-[var(--color-accent-400)]"
              aria-label={`View ${project.name} repository on GitHub`}
            >
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
              </svg>
              Repository
            </a>
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-[var(--spacing-2)] text-sm font-medium text-[var(--color-neutral-700)] transition-colors hover:text-[var(--color-accent-500)] dark:text-[var(--color-neutral-300)] dark:hover:text-[var(--color-accent-400)]"
                aria-label={`Visit ${project.name} website`}
              >
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
                </svg>
                Website
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
